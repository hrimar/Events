# Copy this file to .env and fill in the real values.
# The .env file is in .gitignore and must NEVER be committed to source control.

# Azure Storage Account connection string — get from portal.azure.com:
# Storage accounts ? <your account> ? Access keys ? Connection string
AZURE_WEBJOBS_STORAGE=DefaultEndpointsProtocol=https;AccountName=<storage_account_name>;AccountKey=<key>;EndpointSuffix=core.windows.net

EVENTS_CONNECTION_STRING=Server=tcp:<server>.database.windows.net,1433;Initial Catalog=<db>;User ID=<user>;Password=<password>;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;
CLAUDE_API_KEY=sk-ant-api03-...
GROQ_API_KEY=gsk_...
