@model Events.Web.Models.WeeklyEventsViewModel
@using Events.Web.Resources
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResources> Localizer
@{
    var displayCulture = System.Globalization.CultureInfo.CurrentCulture;
    var allDayNames = displayCulture.DateTimeFormat.AbbreviatedDayNames;
    var calDayNames = new[] { allDayNames[1], allDayNames[2], allDayNames[3], allDayNames[4], allDayNames[5], allDayNames[6], allDayNames[0] };
    const int desktopDayCount = 4;
    const int mobileDayCount = 6;
    var prevFromDesktop = Model.FromDate.AddDays(-desktopDayCount).ToString("yyyy-MM-dd");
    var nextFromDesktop = Model.FromDate.AddDays(desktopDayCount).ToString("yyyy-MM-dd");
    var prevFromMobile = Model.FromDate.AddDays(-mobileDayCount).ToString("yyyy-MM-dd");
    var nextFromMobile = Model.FromDate.AddDays(mobileDayCount).ToString("yyyy-MM-dd");
    var todayFrom = DateTime.Today.ToString("yyyy-MM-dd");
    var isCurrentWeek = Model.FromDate.Date == DateTime.Today.Date;
    var desktopPeriodLabel = Model.FromDate.ToString("d MMM", displayCulture) + " – " + Model.FromDate.AddDays(desktopDayCount - 1).ToString("d MMM yyyy", displayCulture);
    var mobilePeriodLabel = Model.FromDate.ToString("d MMM", displayCulture) + " – " + Model.FromDate.AddDays(mobileDayCount - 1).ToString("d MMM yyyy", displayCulture);
    var sectionTitle = isCurrentWeek ? Localizer["Home_WeeklySectionTitle"].Value : Localizer["Home_UpcomingSectionTitle"].Value;

    var dayList = Model.ByDay;
    int todayIndex = dayList.FindIndex(d => d.IsToday);
    int mobileActiveIndex = todayIndex >= 0 ? todayIndex : 0;
}

<style>
    .day-chips::-webkit-scrollbar { height: 6px; }
    .day-chips::-webkit-scrollbar-track { background: transparent; }
    .day-chips::-webkit-scrollbar-thumb { background: #c7ccd1; border-radius: 3px; }
    .day-chip.active { background: var(--bs-primary, #1f6feb); border-color: var(--bs-primary, #1f6feb); color: #fff; }
    .day-chip.active .badge { background: rgba(255,255,255,.25) !important; }
</style>

<section class="py-4 bg-surface theme-section border-top" id="weekly-events-section">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h4 mb-0">
                <i class="fas fa-calendar-week text-primary me-2"></i>@sectionTitle
            </h2>
            <a asp-controller="Events" asp-action="Index"
               asp-route-fromDate="@Model.FromDate.ToString("yyyy-MM-dd")"
               asp-route-toDate="@Model.ToDate.ToString("yyyy-MM-dd")"
               class="btn btn-sm btn-outline-primary">
                <i class="fas fa-list me-1"></i>@Localizer["Home_ViewAllEvents"]
            </a>
        </div>

        <!-- Period Navigator: desktop/tablet steps 4 days, mobile steps 6 days -->
        <div class="d-flex align-items-center justify-content-center gap-2 mb-3">
            <button class="btn btn-sm btn-outline-secondary week-nav-btn" data-from-desktop="@prevFromDesktop" data-from-mobile="@prevFromMobile">
                <i class="fas fa-chevron-left"></i>
            </button>
            <span class="fw-semibold text-body text-center d-none d-md-inline-block" style="min-width:200px;">@desktopPeriodLabel</span>
            <span class="fw-semibold text-body text-center d-md-none" style="min-width:200px;">@mobilePeriodLabel</span>
            <button class="btn btn-sm btn-outline-secondary week-nav-btn" data-from-desktop="@nextFromDesktop" data-from-mobile="@nextFromMobile">
                <i class="fas fa-chevron-right"></i>
            </button>
            @if (!isCurrentWeek)
            {
                <button class="btn btn-sm btn-outline-primary week-nav-btn ms-2 d-none d-md-inline-block" data-from-desktop="@todayFrom" data-from-mobile="@todayFrom">
                    <i class="fas fa-home me-1"></i>@Localizer["Home_ThisWeek"]
                </button>
            }
        </div>

        <!-- Tab Navigation -->
        <ul class="nav nav-tabs mb-3" id="weeklyTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="tab-day-btn" data-bs-toggle="tab"
                        data-bs-target="#tab-day" type="button" role="tab">
                    <i class="fas fa-sun me-1"></i>@Localizer["Home_TabByDay"]
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="tab-cat-btn" data-bs-toggle="tab"
                        data-bs-target="#tab-cat" type="button" role="tab">
                    <i class="fas fa-layer-group me-1"></i>@Localizer["Home_TabByCategory"]
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="tab-weekend-btn" data-bs-toggle="tab"
                        data-bs-target="#tab-weekend" type="button" role="tab">
                    <i class="fas fa-umbrella-beach me-1"></i>@Localizer["Home_TabWeekend"]
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="tab-cal-btn" data-bs-toggle="tab"
                        data-bs-target="#tab-cal" type="button" role="tab">
                    <i class="fas fa-calendar-alt me-1"></i>@Localizer["Home_TabCalendar"]
                </button>
            </li>
        </ul>

        <div class="tab-content" id="weeklyTabsContent">

            <!-- TAB 1: By Day -->
            <div class="tab-pane fade show active" id="tab-day" role="tabpanel">

                <!-- Tablet/Desktop: 4 equal-width day columns (period navigated via the Period Navigator above) -->
                <div class="d-none d-md-block" data-view="day-desktop">
                    <div style="display:flex; gap:0.75rem;">
                        @for (int i = 0; i < Math.Min(4, dayList.Count); i++)
                        {
                            var day = dayList[i];
                            <div style="flex:1 1 0; min-width:0;">
                                <div class="card h-100 border-@(day.IsToday ? "primary" : "light") shadow-sm">
                                    <div class="card-header py-2 @(day.IsToday ? "bg-primary text-white" : "bg-surface-alt text-body") text-center">
                                        <div class="fw-bold text-capitalize">
                                            @if (day.IsToday)
                                            {
                                                @Localizer["Home_Today"]
                                            }
                                            else
                                            {
                                                @day.Date.ToString("dddd", displayCulture)
                                            }
                                        </div>
                                        <small class="opacity-75">@day.Date.ToString("d MMM", displayCulture)</small>
                                    </div>
                                    <div class="card-body p-2" style="max-height:380px; overflow-y:auto;">
                                        @if (!day.Events.Any())
                                        {
                                            <p class="text-muted text-center small mt-3">@Localizer["Home_NoEventsForDay"]</p>
                                        }
                                        else
                                        {
                                            @foreach (var ev in day.Events.Take(10))
                                            {
                                                <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id"
                                                   class="text-decoration-none d-block mb-2">
                                                    <div class="d-flex gap-2 align-items-start p-1 rounded">
                                                        <img src="@ev.DefaultImage" alt="@ev.Name"
                                                             style="width:48px;height:48px;object-fit:cover;border-radius:4px;flex-shrink:0;"
                                                             onerror="this.src='/images/default_event_image.jpeg'">
                                                        <div style="min-width:0;">
                                                            <div class="text-body small fw-semibold text-clamp-2">@ev.Name</div>
                                                            @if (ev.HasKnownTime)
                                                            {
                                                                <div class="text-muted" style="font-size:0.75rem;">@ev.FormattedTime</div>
                                                            }
                                                            @if (ev.IsFree)
                                                            {
                                                                <span class="badge bg-success" style="font-size:0.65rem;">@Localizer["Home_Free"]</span>
                                                            }
                                                        </div>
                                                    </div>
                                                </a>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Mobile: day chips + single-day event list -->
                <div class="d-md-none" data-view="day-mobile">
                    <div class="day-chips" style="display:flex; gap:0.5rem; overflow-x:auto; padding-bottom:0.5rem; scrollbar-width:thin;">
                        @for (int i = 0; i < dayList.Count; i++)
                        {
                            var day = dayList[i];
                            var isActive = i == mobileActiveIndex;
                            <div class="day-chip@(isActive ? " active" : "")" data-day-index="@i"
                                 style="flex:0 0 auto; min-width:56px; padding:6px 8px; border-radius:12px; border:1.5px solid var(--bs-border-color, #e2e6ea); text-align:center; cursor:pointer;">
                                <div class="small fw-semibold text-capitalize" style="font-size:0.7rem;">
                                    @(day.IsToday ? Localizer["Home_Today"].Value : day.Date.ToString("ddd", displayCulture))
                                </div>
                                <div class="fw-bold" style="font-size:0.95rem;">@day.Date.Day</div>
                                <span class="badge bg-secondary" style="font-size:0.65rem;">@day.Events.Count</span>
                            </div>
                        }
                    </div>
                    <div class="day-chip-panels mt-2">
                        @for (int i = 0; i < dayList.Count; i++)
                        {
                            var day = dayList[i];
                            var isActive = i == mobileActiveIndex;
                            <div class="day-chip-panel" data-day-index="@i" style="@(isActive ? "" : "display:none;")">
                                @if (!day.Events.Any())
                                {
                                    <p class="text-muted text-center small py-4">@Localizer["Home_NoEventsForDay"]</p>
                                }
                                else
                                {
                                    @foreach (var ev in day.Events)
                                    {
                                        <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id"
                                           class="text-decoration-none d-block mb-2">
                                            <div class="d-flex gap-2 align-items-center p-2 rounded border">
                                                <img src="@ev.DefaultImage" alt="@ev.Name"
                                                     style="width:56px;height:56px;object-fit:cover;border-radius:8px;flex-shrink:0;"
                                                     onerror="this.src='/images/default_event_image.jpeg'">
                                                <div style="min-width:0; flex:1 1 auto;">
                                                    <div class="text-body small fw-semibold text-clamp-2">@ev.Name</div>
                                                    <div class="text-muted" style="font-size:0.75rem;">@ev.Location</div>
                                                    @if (ev.HasKnownTime)
                                                    {
                                                        <div class="text-primary fw-semibold" style="font-size:0.75rem;">@ev.FormattedTime</div>
                                                    }
                                                    @if (ev.IsFree)
                                                    {
                                                        <span class="badge bg-success" style="font-size:0.65rem;">@Localizer["Home_Free"]</span>
                                                    }
                                                </div>
                                            </div>
                                        </a>
                                    }
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- TAB 2: By Category -->
            <div class="tab-pane fade" id="tab-cat" role="tabpanel">
                @if (!Model.ByCategory.Any())
                {
                    <p class="text-muted text-center py-4">@Localizer["Home_NoEventsForDay"]</p>
                }
                else
                {
                    @foreach (var cat in Model.ByCategory)
                    {
                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h5 class="mb-0 text-body">
                                    <i class="@cat.IconClass me-2 text-primary"></i>@cat.DisplayName
                                    <span class="badge bg-secondary ms-1" style="font-size:0.75rem;">@cat.Events.Count</span>
                                </h5>
                                <a asp-controller="Events" asp-action="Index"
                                   asp-route-category="@cat.CategoryKey"
                                   asp-route-fromDate="@Model.FromDate.ToString("yyyy-MM-dd")"
                                   asp-route-toDate="@Model.ToDate.ToString("yyyy-MM-dd")"
                                   class="btn btn-sm btn-outline-secondary">
                                    @Localizer["Home_ViewAllCategory"]
                                </a>
                            </div>
                            <div style="display:flex; gap:0.75rem; overflow-x:auto; padding-bottom:0.5rem;">
                                @foreach (var ev in cat.Events.Take(8))
                                {
                                    <div style="min-width:175px; max-width:175px; flex-shrink:0;">
                                        <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id"
                                           class="text-decoration-none">
                                            <div class="card shadow-sm h-100 border-0">
                                                <img src="@ev.DefaultImage" alt="@ev.Name"
                                                     style="height:100px;object-fit:cover;border-radius:4px 4px 0 0;"
                                                     onerror="this.src='/images/default_event_image.jpeg'">
                                                <div class="card-body p-2">
                                                    <div class="text-body small fw-semibold text-truncate">@ev.Name</div>
                                                    <div class="text-muted" style="font-size:0.75rem;">
                                                        @ev.FormattedDate@(ev.HasKnownTime ? " · " + ev.FormattedTime : "")
                                                    </div>
                                                    @if (ev.IsFree)
                                                    {
                                                        <span class="badge bg-success" style="font-size:0.65rem;">@Localizer["Home_Free"]</span>
                                                    }
                                                </div>
                                            </div>
                                        </a>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- TAB 3: Wekend -->
            <div class="tab-pane fade" id="tab-weekend" role="tabpanel">
                @if (!Model.WeekendEvents.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="fas fa-umbrella-beach fa-2x mb-3"></i>
                        <p>@Localizer["Home_NoWeekendEvents"]</p>
                    </div>
                }
                else
                {
                    <div class="row row-cols-1 row-cols-md-2 g-3">
                        @foreach (var ev in Model.WeekendEvents)
                        {
                            <div class="col">
                                <div class="card event-card h-100 shadow-sm border-0">
                                    <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id"
                                       class="text-decoration-none">
                                        <div class="event-image-container">
                                            <img src="@ev.DefaultImage" alt="@ev.Name"
                                                 class="event-image-full"
                                                 onerror="this.src='/images/default_event_image.jpeg'">
                                            @if (ev.IsFree)
                                            {
                                                <div class="event-price event-free">@Localizer["Home_Free"]</div>
                                            }
                                        </div>
                                    </a>
                                    <div class="card-body d-flex flex-column">
                                        <h6 class="event-title">
                                            <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id"
                                               class="text-decoration-none text-body">@ev.Name</a>
                                        </h6>
                                        <div class="text-muted small">
                                            <i class="fas fa-calendar me-1"></i>
                                            @ev.FormattedDate@(ev.HasKnownTime ? " · " + ev.FormattedTime : "")
                                        </div>
                                        <div class="text-muted small mt-1">
                                            <i class="fas fa-map-marker-alt me-1"></i>
                                            @if (!string.IsNullOrEmpty(ev.VenueSlug))
                                            {
                                                <a asp-area="" asp-controller="Venues" asp-action="Details"
                                                   asp-route-slug="@ev.VenueSlug"
                                                   class="text-muted text-decoration-none">@ev.Location</a>
                                            }
                                            else
                                            {
                                                @ev.Location
                                            }
                                        </div>
                                    </div>
                                    <div class="card-footer bg-transparent border-0 pt-0">
                                        <div class="d-flex justify-content-between">
                                            <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id"
                                               class="btn btn-outline-primary btn-sm">
                                                <i class="fas fa-info-circle me-1"></i>@Localizer["Home_Details"]
                                            </a>
                                            @if (ev.HasTicketUrl)
                                            {
                                                <a href="@ev.TicketUrl" target="_blank" class="btn btn-primary btn-sm">
                                                    <i class="fas fa-ticket-alt me-1"></i>@Localizer["Home_BuyTickets"]
                                                </a>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- TAB 4: Calendar -->
            <div class="tab-pane fade" id="tab-cal" role="tabpanel">
                @{
                    var showTwoMonths = Model.FromDate.Year != Model.ToDate.Year
                                     || Model.FromDate.Month != Model.ToDate.Month;
                    var monthsToRender = new List<DateTime>
                    {
                        new DateTime(Model.FromDate.Year, Model.FromDate.Month, 1)
                    };
                    if (showTwoMonths)
                        monthsToRender.Add(new DateTime(Model.ToDate.Year, Model.ToDate.Month, 1));
                }
                <div class="row g-3">
                    @foreach (var monthStart in monthsToRender)
                    {
                        var mLastDay = new DateTime(monthStart.Year, monthStart.Month,
                            DateTime.DaysInMonth(monthStart.Year, monthStart.Month));
                        int mStartOffset = ((int)monthStart.DayOfWeek + 6) % 7; // ISO: Mon=0
                        var mCalStart = monthStart.AddDays(-mStartOffset);
                        int mTotalCells = (int)Math.Ceiling((mStartOffset + mLastDay.Day) / 7.0) * 7;

                        <div class="@(showTwoMonths ? "col-md-6" : "col-12")">
                            <div class="text-center fw-semibold mb-2 text-capitalize text-body">
                                @monthStart.ToString("MMMM yyyy", displayCulture)
                            </div>
                            <div class="table-responsive">
                                <table class="table table-bordered text-center mb-0 weekly-calendar-table">
                                    <thead>
                                        <tr>
                                            @foreach (var dn in calDayNames)
                                            {
                                                <th class="py-1" style="font-size:0.8rem;">@dn</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (int cell = 0; cell < mTotalCells; cell += 7)
                                        {
                                            <tr>
                                                @for (int col = 0; col < 7; col++)
                                                {
                                                    var cellDate = mCalStart.AddDays(cell + col);
                                                    var isCurrentMonth = cellDate.Month == monthStart.Month;
                                                    var isTodayCell = cellDate.Date == DateTime.Today;
                                                    var isInPeriod = isCurrentMonth
                                                        && cellDate.Date >= Model.FromDate.Date
                                                        && cellDate.Date <= Model.ToDate.Date;
                                                    var count = Model.CalendarCounts.GetValueOrDefault(cellDate.Date, 0);
                                                    var tdClass = isTodayCell           ? "calendar-day-today"
                                                                : isInPeriod            ? "calendar-day-in-period"
                                                                : !isCurrentMonth       ? "text-muted opacity-50"
                                                                : "";
                                                    <td class="p-1 @tdClass"
                                                        style="min-width:40px; height:52px; vertical-align:top; font-size:0.85rem;">
                                                        @if (isCurrentMonth && count > 0)
                                                        {
                                                            <a asp-controller="Events" asp-action="Index"
                                                               asp-route-fromDate="@cellDate.ToString("yyyy-MM-dd")"
                                                               asp-route-toDate="@cellDate.ToString("yyyy-MM-dd")"
                                                               class="text-decoration-none text-body d-flex flex-column align-items-center">
                                                                <span>@cellDate.Day</span>
                                                                <span class="badge bg-primary" style="font-size:0.65rem;">@count</span>
                                                            </a>
                                                        }
                                                        else
                                                        {
                                                            <span>@(isCurrentMonth ? cellDate.Day.ToString() : "")</span>
                                                        }
                                                    </td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function () {
    // Keep active tab between reloads when navigating weeks
    const ACTIVE_TAB_KEY = 'weeklyActiveTab';

    document.addEventListener('click', function (e) {
        const btn = e.target.closest('.week-nav-btn');
        if (!btn) return;

        const isDesktop = window.matchMedia('(min-width: 768px)').matches;
        const fromDate = isDesktop ? btn.dataset.fromDesktop : btn.dataset.fromMobile;
        const section = document.getElementById('weekly-events-section');
        if (!section || !fromDate) return;
        
        // Keep current active tab
        const activeTab = document.querySelector('#weeklyTabs .nav-link.active');
        if (activeTab) sessionStorage.setItem(ACTIVE_TAB_KEY, activeTab.dataset.bsTarget);

        section.style.opacity = '0.5';
        section.style.pointerEvents = 'none';

        fetch(`/Home/WeeklyEventsPartial?fromDate=${fromDate}`)
            .then(r => r.text())
            .then(html => {
                section.outerHTML = html;

                // Restore active tab
                const savedTab = sessionStorage.getItem(ACTIVE_TAB_KEY);
                if (savedTab) {
                    const tabBtn = document.querySelector(`[data-bs-target="${savedTab}"]`);
                    if (tabBtn) new bootstrap.Tab(tabBtn).show();
                }
            })
            .catch(() => {
                section.style.opacity = '1';
                section.style.pointerEvents = '';
            });
    });

    // Mobile: switch the visible day chip / event list
    document.addEventListener('click', function (e) {
        const chip = e.target.closest('.day-chip');
        if (chip) {
            const wrapper = chip.closest('[data-view="day-mobile"]');
            if (!wrapper) return;

            wrapper.querySelectorAll('.day-chip').forEach(c => c.classList.toggle('active', c === chip));
            const idx = chip.dataset.dayIndex;
            wrapper.querySelectorAll('.day-chip-panel').forEach(p => {
                p.style.display = (p.dataset.dayIndex === idx) ? '' : 'none';
            });
        }
    });
});
</script>
