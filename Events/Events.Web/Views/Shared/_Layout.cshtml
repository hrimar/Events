@using Events.Models.Enums
@using Events.Web.Models
@using Events.Web.Resources
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResources> Localizer

<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Google Analytics tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-NL0QFW80H6"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-NL0QFW80H6');
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script>
        (function () {
            var t = localStorage.getItem('selectedTheme');
            if (!t) {
                t = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            }
            document.documentElement.setAttribute('data-theme', t);
        })();
    </script>
    <title>@(ViewData["PageTitle"] ?? ViewData["Title"] + " — Sofia Events")</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- Theme CSS Files -->
    <link rel="stylesheet" href="~/css/themes/light-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/themes/dark-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/events-portal.css" asp-append-version="true" />
    
    <!-- Open Graph meta tags for better social sharing -->
    @await RenderSectionAsync("MetaTags", required: false)
    @if (ViewData["MetaDescription"] != null)
    {
        <meta name="description" content="@ViewData["MetaDescription"]" />
        <meta property="og:title" content="@(ViewData["OgTitle"] ?? ViewData["Title"])" />
        <meta property="og:description" content="@ViewData["MetaDescription"]" />
        @if (!string.IsNullOrEmpty(ViewData["OgImageUrl"]?.ToString()))
        {
            <meta property="og:image" content="@ViewData["OgImageUrl"]" />
        }
        @if (!string.IsNullOrEmpty(ViewData["OgUrl"]?.ToString()))
        {
            <meta property="og:url" content="@ViewData["OgUrl"]" />
        }
        <meta property="og:type" content="website" />
    }
    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
<nav class="navbar navbar-expand-lg shadow-sm">
    <div class="container">
        <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
            <img src="~/images/logo.jpeg" alt="Go Sofia Events" class="navbar-logo" width="200" height="70" loading="eager" decoding="async" fetchpriority="high" />
            <span class="visually-hidden">Sofia Events</span>
        </a>
        
        <!-- Mobile/Tablet controls: search toggle + hamburger, kept on a single row with the logo -->
        <div class="d-flex align-items-center gap-1 d-lg-none">
            <button class="btn nav-link p-2 navbar-icon-btn" type="button" data-bs-toggle="collapse" data-bs-target="#mobile-search-bar"
                    aria-expanded="false" aria-controls="mobile-search-bar" aria-label="@Localizer["Nav_SearchPlaceholderMobile"]">
                <i class="fas fa-search"></i>
            </button>
            <button class="btn nav-link p-2 navbar-icon-btn" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <i class="fas fa-bars"></i>
            </button>
        </div>

        <div class="navbar-collapse collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="fas fa-home me-1"></i>@Localizer["Nav_Home"]
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Events" asp-action="Index">
                        <i class="fas fa-calendar me-1"></i>@Localizer["Nav_AllEvents"]
                    </a>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                        <i class="fas fa-filter me-1"></i>@Localizer["Nav_Categories"]
                    </a>
                    <ul class="dropdown-menu">
                        @foreach(var category in EventsPageViewModel.GetAvailableCategories(Localizer))
                        {
                            <li>
                                <a class="dropdown-item" asp-area="" asp-controller="Events"
                                   asp-action="Index" asp-route-category="@category.Value">
                                    <i class="@category.IconClass me-2"></i>@category.DisplayName
                                </a>
                            </li>
                        }
                    </ul>
                </li>
                <!-- Venues and Free Events: only in the mobile/tablet hamburger menu, desktop users reach them via the Home page hero buttons -->
                <li class="nav-item d-lg-none">
                    <a class="nav-link" asp-area="" asp-controller="Venues" asp-action="Index">
                        <i class="fas fa-map-marker-alt me-1"></i>@Localizer["Venue_BrowseVenues"]
                    </a>
                </li>
                <li class="nav-item d-lg-none">
                    <a class="nav-link" asp-area="" asp-controller="Events" asp-action="Index" asp-route-free="true">
                        <i class="fas fa-gift me-1"></i>@Localizer["Home_FreeEvents"]
                    </a>
                </li>
                @if (User.IsInRole("Administrator") || User.IsInRole("EventManager"))
                {
                    <li class="nav-item">
                        <a class="nav-link text-warning" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                            <i class="fas fa-cog me-1"></i>@Localizer["Nav_AdminPanel"]
                        </a>
                    </li>
                }
            </ul>
            
            <!-- Desktop Navigation Search with Tag Support -->
            <div class="d-none d-lg-flex flex-grow-1 mx-4 position-relative">
                <form asp-area="" asp-controller="Events" asp-action="Index" method="get" class="d-flex w-100">
                    <input class="form-control me-2" type="search" name="search" id="navbar-search" 
                           placeholder="Search events or #tags..." autocomplete="off">
                    <button class="btn btn-primary" type="submit">
                        <i class="fas fa-search"></i>
                    </button>
                </form>
                <!-- Hidden autocomplete container -->
                <div id="navbar-search-results" class="position-absolute top-100 start-0 w-100 theme-dropdown border rounded-bottom shadow-lg" style="display: none; z-index: 1000; max-height: 300px; overflow-y: auto;"></div>
            </div>
            
            <!-- Theme Switcher -->
            <div class="me-3">
                <partial name="_ThemeSwitcher" />
            </div>

            <!-- Language Switcher -->
            <div class="me-3">
                <partial name="_LanguageSwitcher" />
            </div>
            
            <partial name="_LoginPartial" />
        </div>
        
        <!-- Mobile Search Bar: collapsed by default, expanded via the search icon next to the hamburger -->
        <div class="collapse d-lg-none w-100 mt-2 border-top pt-2" id="mobile-search-bar">
            <form asp-area="" asp-controller="Events" asp-action="Index" method="get" class="d-flex gap-2">
                <input class="form-control" type="search" name="search" id="mobile-navbar-search" 
                       placeholder="Search events..." autocomplete="off">
                <button class="btn btn-primary" type="submit">
                    <i class="fas fa-search"></i>
                </button>
            </form>
            <div id="mobile-navbar-search-results" class="position-absolute w-100 theme-dropdown border rounded shadow-lg mt-1" style="display: none; z-index: 1000; max-height: 300px; overflow-y: auto; margin-left: -12px; margin-right: -12px; max-width: calc(100% + 24px);"></div>
        </div>
        
    </div>
</nav>

<main>
    @RenderBody()
</main>

<!-- Footer -->
<footer class="text-white py-4 mt-5">
    <div class="container">
        <div class="row gy-4">
            <!-- Brand -->
            <div class="col-md-4">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="d-inline-block mb-2">
                    <img src="~/images/logo.jpeg" alt="Go Sofia Events" class="footer-logo" width="160" height="56" loading="lazy" decoding="async" />
                </a>
                <p class="text-white-50 mb-3">@Localizer["Footer_Description"]</p>
                <a href="https://www.facebook.com/GoSofia" target="_blank" rel="noopener noreferrer"
                   class="text-white-50 text-decoration-none footer-social-link" title="Facebook">
                    <i class="fab fa-facebook-f" style="font-size: 1.2rem;"></i>
                </a>
            </div>

            <!-- Explore -->
            <div class="col-6 col-md-4">
                <h6 class="mb-3">@Localizer["Footer_ExploreHeading"]</h6>
                <div class="d-flex flex-column gap-2">
                    <a asp-area="" asp-controller="Events" asp-action="Index" class="text-white-50 text-decoration-none footer-link">
                        @Localizer["Nav_AllEvents"]
                    </a>
                    <a asp-area="" asp-controller="Venues" asp-action="Index" class="text-white-50 text-decoration-none footer-link">
                        @Localizer["Venue_BrowseVenues"]
                    </a>
                    <a asp-area="" asp-controller="Events" asp-action="Index" asp-route-free="true" class="text-white-50 text-decoration-none footer-link">
                        @Localizer["Home_FreeEvents"]
                    </a>
                </div>
            </div>

            <!-- Information -->
            <div class="col-6 col-md-4">
                <h6 class="mb-3">@Localizer["Footer_InfoHeading"]</h6>
                <div class="d-flex flex-column gap-2">
                    <a asp-controller="Home" asp-action="AboutUs" class="text-white-50 text-decoration-none footer-link">
                        @Localizer["Footer_AboutUs"]
                    </a>
                    <a asp-controller="Home" asp-action="Privacy" class="text-white-50 text-decoration-none footer-link">
                        @Localizer["Footer_PrivacyPolicy"]
                    </a>
@*                     <a asp-controller="Contact" asp-action="Index" class="text-white-50 text-decoration-none footer-link">
                        @Localizer["Footer_ContactUs"]
                    </a> *@
                    <a href="mailto:office@go-sofia.com" class="text-white-50 text-decoration-none footer-link">
                        <i class="fas fa-envelope me-1"></i>office@go-sofia.com
                    </a>
                </div>
            </div>
        </div>

        <hr class="border-secondary my-3" />

        <div class="row align-items-center">
            <div class="col-md-6">
                <small class="text-white-50">&copy; @DateTime.Now.Year Go Sofia. @Localizer["Footer_Copyright"]</small>
            </div>
            <div class="col-md-6 d-flex justify-content-md-end mt-2 mt-md-0">
                <partial name="_LanguageSwitcher" />
            </div>
        </div>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/theme-switcher.js" asp-append-version="true"></script>

<!-- Enhanced Navigation Search Script -->
<script>
$(document).ready(function() {
    initializeSearch('#navbar-search', '#navbar-search-results', false);
    initializeSearch('#mobile-navbar-search', '#mobile-navbar-search-results', true);

    // Focus the mobile search field once it expands after tapping the search icon
    document.getElementById('mobile-search-bar')?.addEventListener('shown.bs.collapse', function () {
        document.getElementById('mobile-navbar-search')?.focus();
    });

    function initializeSearch(searchInputSelector, resultsContainerSelector, isMobile) {
        let searchTimeout;
        const searchInput = $(searchInputSelector);
        const resultsContainer = $(resultsContainerSelector);
        
        searchInput.on('input', function() {
            clearTimeout(searchTimeout);
            const query = $(this).val().trim();
            
            if (query.length >= 2) {
                searchTimeout = setTimeout(() => {
                    performSearch(query);
                }, 300);
            } else {
                resultsContainer.hide();
            }
        });
        
        // Hide results when clicking outside
        $(document).on('click', function(e) {
            const isClickInsideSearch = $(e.target).closest(searchInputSelector).length > 0 || 
                                       $(e.target).closest(resultsContainerSelector).length > 0;
            if (!isClickInsideSearch) {
                resultsContainer.hide();
            }
        });
        
        // Handle search result clicks
        $(document).on('click', `.${searchInputSelector.substring(1)}-item`, function(e) {
            e.preventDefault();
            const isTag = $(this).data('is-tag');
            const value = $(this).data('value');
            
            if (isTag) {
                const tagParam = encodeURIComponent(value);
                const url = `/Events?tags=${tagParam}`;
                window.location.href = url;
            } else {
                const eventId = $(this).data('id');
                window.location.href = `/Events/Details/${eventId}`;
            }
        });
        
        function performSearch(query) {
            $.ajax({
                url: '/Events/Search',
                data: { query: query },
                success: function(data) {
                    displaySearchResults(data, query);
                },
                error: function() {
                    resultsContainer.hide();
                }
            });
        }
        
        function displaySearchResults(data, query) {
            if (!data || data.length === 0) {
                resultsContainer.hide();
                return;
            }
            
            let html = '<div class="p-2">';
            
            const events = data.filter(item => !item.isTag);
            const tags = data.filter(item => item.isTag);
            
            if (tags.length > 0) {
                html += '<div class="mb-2"><small class="text-muted fw-bold">Tags</small></div>';
                tags.forEach(item => {
                    html += `
                        <div class="navbar-search-item p-2 rounded hover-bg-surface cursor-pointer" 
                             data-is-tag="true" data-value="${item.tagName}">
                            <i class="fas fa-tag text-info me-2"></i>
                            <strong>${item.name}</strong> 
                            <small class="text-muted">${item.location}</small>
                        </div>`;
                });
            }
            
            if (events.length > 0) {
                if (tags.length > 0) {
                    html += '<hr class="my-2">';
                }
                html += '<div class="mb-2"><small class="text-muted fw-bold">Events</small></div>';
                events.slice(0, 4).forEach(item => {
                    html += `
                        <div class="navbar-search-item p-2 rounded hover-bg-surface cursor-pointer" 
                             data-is-tag="false" data-id="${item.id}">
                            <i class="fas fa-calendar text-primary me-2"></i>
                            <strong>${item.name}</strong><br>
                            <small class="text-muted">${item.category || ''} ${item.date ? '• ' + item.date : ''}</small>
                        </div>`;
                });
            }
            
            html += '</div>';
            resultsContainer.html(html).show();
        }
    }
});
</script>

<style>
    .hover-bg-surface:hover {
        background-color: var(--hover-bg) !important;
    }
    
    .cursor-pointer {
        cursor: pointer;
    }
    
    .navbar-search-item {
        transition: background-color 0.2s ease;
    }

    /* Mobile search/hamburger toggle buttons: no lingering focus ring after a mouse/touch click,
       keep it for keyboard navigation (accessibility) */
    .navbar-icon-btn:focus {
        box-shadow: none;
    }

    .navbar-icon-btn:focus-visible {
        box-shadow: 0 0 0 0.2rem rgba(var(--bs-primary-rgb), 0.25);
    }

    /* Desktop: Login buttons on one line */
    @@media (min-width: 992px) {
        .navbar-nav:last-child {
            flex-direction: row;
        }
    }

    /* Mobile/Tablet hamburger menu: group the nav links, theme/language switchers
       and login section into visually separated blocks */
    @@media (max-width: 991.98px) {
        #navbarNav .navbar-nav.me-auto {
            border-bottom: 1px solid var(--border-color, rgba(0, 0, 0, 0.08));
            margin-bottom: 0.5rem;
            padding-bottom: 0.5rem;
        }

        #navbarNav > .me-3 {
            margin: 0.5rem 0 !important;
        }

        #navbarNav > .navbar-nav:last-child {
            flex-direction: row;
            gap: 0.5rem;
            border-top: 1px solid var(--border-color, rgba(0, 0, 0, 0.08));
            margin-top: 0.5rem;
            padding-top: 0.5rem;
        }
    }

    .footer-link {
        transition: color 0.2s ease;
        font-size: 0.9rem;
    }

    .footer-link:hover {
        color: #fff !important;
    }

    .footer-social-link {
        transition: color 0.2s ease;
    }

    .footer-social-link:hover {
        color: #fff !important;
    }

    .footer-logo {
        max-height: 40px;
        height: auto;
        width: auto;
        object-fit: contain;
    }

    /* The footer background is always dark regardless of theme, so the language
       switcher needs its own contrast instead of the theme-driven btn-outline-secondary */
    footer .language-switcher .btn-outline-secondary {
        color: rgba(255, 255, 255, 0.75);
        border-color: rgba(255, 255, 255, 0.35);
    }

    footer .language-switcher .btn-outline-secondary:hover {
        background-color: rgba(255, 255, 255, 0.15);
        color: #fff;
    }

</style>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>