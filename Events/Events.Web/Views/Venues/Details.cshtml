@model Events.Web.Models.VenueDetailsViewModel
@using Events.Web.Resources
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResources> Localizer
@{
    ViewData["PageTitle"] = Model.Name + " — " + Localizer["Venue_SeoTitleSuffix"];
    ViewData["Title"] = Model.Name;
    ViewData["MetaDescription"] = Model.Description ?? $"{Localizer["Venue_EventsAtVenue"]}: {Model.Name}";
    ViewData["OgTitle"] = Model.Name + " — Go Sofia";
    ViewData["OgImageUrl"] = Model.PhotoUrl ?? string.Empty;
    var currentUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}";
    ViewData["OgUrl"] = currentUrl;
}

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">@Localizer["Venue_Home"]</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <!-- Venue Header -->
    <div class="card border-0 shadow-sm mb-4">
        @if (!string.IsNullOrEmpty(Model.PhotoUrl))
        {
            <img src="@Model.PhotoUrl" alt="@Model.Name"
                 class="card-img-top"
                 style="max-height: 320px; object-fit: cover; object-position: center;"
                 onerror="this.style.display='none'">
        }
        <div class="card-body">
            <div class="row align-items-start">
                <div class="col-lg-8">
                    <h1 class="h2 mb-1">@Model.DisplayName</h1>
                    @if (!string.IsNullOrEmpty(Model.ShortName))
                    {
                        <span class="badge bg-secondary mb-2">@Model.ShortName</span>
                    }

                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <p class="text-muted mt-2">@Model.Description</p>
                    }

                    <div class="d-flex flex-wrap gap-3 mt-3">
                        @if (!string.IsNullOrEmpty(Model.Address))
                        {
                            <span class="text-muted">
                                <i class="fas fa-map-marker-alt me-1 text-primary"></i>@Model.Address
                            </span>
                        }
                        @if (Model.Capacity.HasValue)
                        {
                            <span class="text-muted">
                                <i class="fas fa-users me-1 text-primary"></i>
                                @Localizer["Venue_Capacity"]: @Model.Capacity
                            </span>
                        }
                        @if (!string.IsNullOrEmpty(Model.WebsiteUrl))
                        {
                            <a href="@Model.WebsiteUrl" target="_blank" rel="noopener"
                               class="text-decoration-none">
                                <i class="fas fa-globe me-1"></i>@Localizer["Venue_OfficialSite"]
                            </a>
                        }
                    </div>
                </div>
                <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                    <a asp-controller="Events" asp-action="Index"
                       asp-route-fromDate="@DateTime.Today.ToString("yyyy-MM-dd")"
                       class="btn btn-outline-primary">
                        <i class="fas fa-calendar me-1"></i>@Localizer["Venue_AllEvents"]
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Upcoming Events -->
        <div class="col-lg-@(Model.HasMap ? "8" : "12")">
            <h2 class="h4 mb-3">
                <i class="fas fa-calendar-alt me-2 text-primary"></i>@Localizer["Venue_EventsAtVenue"]
                @if (Model.UpcomingEvents.Any())
                {
                    <span class="badge bg-primary ms-1">@Model.UpcomingEvents.Count</span>
                }
            </h2>

            @if (!Model.UpcomingEvents.Any())
            {
                <div class="text-center py-5 text-muted border rounded">
                    <i class="fas fa-calendar-times fa-2x mb-3"></i>
                    <p class="mb-0">@Localizer["Venue_NoEvents"]</p>
                </div>
            }
            else
            {
                <div class="row">
                    @foreach (var ev in Model.UpcomingEvents)
                    {
                        <div class="col-md-6 mb-4">
                            <div class="card event-card h-100">
                                <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id"
                                   class="text-decoration-none">
                                    <div class="event-image-container">
                                        <img src="@ev.DefaultImage"
                                             alt="@ev.Name"
                                             class="event-image-full"
                                             style="aspect-ratio: 16/9; object-fit: cover;"
                                             onerror="this.src='/images/default_event_image.jpeg'">
                                        @if (ev.IsFree)
                                        {
                                            <div class="event-price event-free">@Localizer["Venue_Free"]</div>
                                        }
                                    </div>
                                </a>
                                <div class="card-body d-flex flex-column">
                                    <h5 class="event-title">
                                        <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id"
                                           class="text-decoration-none text-dark">@ev.Name</a>
                                    </h5>
                                    <div class="event-date mb-2">
                                        <i class="fas fa-calendar me-1"></i>
                                        @ev.FormattedDate@(ev.HasKnownTime ? " " + ev.FormattedTime : "")
                                    </div>
                                    @if (!string.IsNullOrEmpty(ev.ShortDescription))
                                    {
                                        <p class="text-muted small flex-grow-1">@ev.ShortDescription</p>
                                    }
                                </div>
                                <div class="card-footer bg-transparent">
                                    <div class="d-flex justify-content-between">
                                        <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id"
                                           class="btn btn-outline-primary btn-sm">
                                            <i class="fas fa-info-circle me-1"></i>@Localizer["Venue_Details"]
                                        </a>
                                        @if (ev.HasTicketUrl)
                                        {
                                            <a href="@ev.TicketUrl" target="_blank"
                                               class="btn btn-primary btn-sm">
                                                <i class="fas fa-ticket-alt me-1"></i>@Localizer["Venue_Tickets"]
                                            </a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Map -->
        @if (Model.HasMap)
        {
            <div class="col-lg-4">
                <h2 class="h4 mb-3">
                    <i class="fas fa-map me-2 text-primary"></i>@Localizer["Venue_Location"]
                </h2>
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-0 overflow-hidden rounded">
                        <iframe
                            src="https://www.openstreetmap.org/export/embed.html?bbox=@Model.BboxMinLon%2C@Model.BboxMinLat%2C@Model.BboxMaxLon%2C@Model.BboxMaxLat&layer=mapnik&marker=@Model.LatStr%2C@Model.LonStr"
                            width="100%"
                            height="320"
                            style="border: 0;"
                            loading="lazy"
                            title="@Model.Name map location">
                        </iframe>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Address))
                    {
                        <div class="card-body py-2">
                            <small class="text-muted">
                                <i class="fas fa-map-marker-alt me-1"></i>@Model.Address
                            </small>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    @if (!string.IsNullOrEmpty(Model.JsonLd))
    {
        <script type="application/ld+json">@Html.Raw(Model.JsonLd)</script>
    }
}