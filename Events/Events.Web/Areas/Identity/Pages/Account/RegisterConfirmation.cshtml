@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = Localizer["RegisterConfirm_Title"];
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card shadow-sm border-0 text-center">
                <div class="card-body p-5">
                    <div class="mb-4">
                        <i class="fas fa-envelope-circle-check fa-4x text-success mb-3"></i>
                        <h2 class="fw-bold">@Localizer["RegisterConfirm_Heading"]</h2>
                    </div>
                    
                    @if (@Model.DisplayConfirmAccountLink)
                    {
                        <div class="alert alert-warning text-start" role="alert">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            <strong>@Localizer["RegisterConfirm_DevMode"]</strong> @Localizer["RegisterConfirm_DevEmailNotConfigured"]
                        </div>
                        
                        <p class="lead mb-4">
                            @Localizer["RegisterConfirm_DevClickLink"]
                        </p>
                        
                        <div class="d-grid gap-2">
                            <a id="confirm-link" href="@Model.EmailConfirmationUrl" class="btn btn-primary btn-lg">
                                <i class="fas fa-check me-2"></i>@Localizer["RegisterConfirm_ConfirmAccount"]
                            </a>
                            <a asp-page="./Login" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i>@Localizer["RegisterConfirm_GoToLogin"]
                            </a>
                        </div>
                        
                        <hr class="my-4">
                        
                        <p class="small text-muted">
                            <a href="https://aka.ms/aspaccountconf" target="_blank">@Localizer["RegisterConfirm_DevDocs"]</a>
                        </p>
                    }
                    else
                    {
                        <p class="lead mb-4">
                            @Localizer["RegisterConfirm_CheckEmail"]
                        </p>
                        
                        <p class="text-muted mb-4">
                            @Localizer["RegisterConfirm_SentLink"]
                        </p>
                        
                        <hr class="my-4">
                        
                        <div>
                            <a asp-page="./Login" class="btn btn-primary">
                                <i class="fas fa-arrow-left me-2"></i>@Localizer["Account_BackToLogin"]
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
