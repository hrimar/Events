@page
@model IndexModel
@{
    ViewData["Title"] = Localizer["Manage_Profile_Title"];
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-3 col-md-4 mb-4 mb-md-0">
            <partial name="_ManageNav" />
        </div>

        <div class="col-lg-9 col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <i class="fas fa-user fa-3x text-primary mb-3"></i>
                        <h2 class="fw-bold">@ViewData["Title"]</h2>
                        <p class="text-muted">@Localizer["Manage_Profile_Subtitle"]</p>
                    </div>

                    <partial name="_StatusMessage" for="StatusMessage" />

                    <form id="profile-form" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        
                        <div class="mb-3">
                            <label asp-for="Username" class="form-label">
                                <i class="fas fa-user-tag me-2"></i>@Localizer["Manage_Username"]
                            </label>
                            <input asp-for="Username" class="form-control form-control-lg" placeholder="@Localizer["Manage_UsernamePlaceholder"]" disabled />
                            <small class="text-muted">@Localizer["Manage_UsernameHint"]</small>
                        </div>
                        
                        <div class="mb-4">
                            <label asp-for="Input.PhoneNumber" class="form-label">
                                <i class="fas fa-phone me-2"></i>@Localizer["Manage_Phone"]
                            </label>
                            <input asp-for="Input.PhoneNumber" class="form-control form-control-lg" placeholder="@Localizer["Manage_PhonePlaceholder"]" />
                            <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="d-grid mb-3">
                            <button id="update-profile-button" type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-save me-2"></i>@Localizer["Manage_SaveChanges"]
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
