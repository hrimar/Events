@page
@using Microsoft.AspNetCore.Http.Features
@model TwoFactorAuthenticationModel
@{
    ViewData["Title"] = Localizer["Manage_2FA_Title"];
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-3 col-md-4 mb-4 mb-md-0">
            <partial name="_ManageNav" />
        </div>

        <div class="col-lg-9 col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-5">
                    <partial name="_StatusMessage" for="StatusMessage" />

                    <div class="text-center mb-4">
                        <i class="fas fa-shield-alt fa-3x text-primary mb-3"></i>
                        <h2 class="fw-bold">@ViewData["Title"]</h2>
                        <p class="text-muted">@Localizer["Manage_2FA_Subtitle"]</p>
                    </div>

                    @{
                        var consentFeature = HttpContext.Features.Get<ITrackingConsentFeature>();
                        @if (consentFeature?.CanTrack ?? true)
                        {
                            @if (Model.Is2faEnabled)
                            {
                                if (Model.RecoveryCodesLeft == 0)
                                {
                                    <div class="alert alert-danger" role="alert">
                                        <i class="fas fa-exclamation-circle me-2"></i>
                                        <strong>@Localizer["Manage_2FA_NoCodes"]</strong>
                                        <p class="mb-0 mt-2">@Localizer["Manage_2FA_NoCodesBeforeLink"] <a asp-page="./GenerateRecoveryCodes">@Localizer["Manage_2FA_GenerateLink"]</a>@Localizer["Manage_2FA_NoCodesAfterLink"]</p>
                                    </div>
                                }
                                else if (Model.RecoveryCodesLeft == 1)
                                {
                                    <div class="alert alert-danger" role="alert">
                                        <i class="fas fa-exclamation-circle me-2"></i>
                                        <strong>@Localizer["Manage_2FA_OneCode"]</strong>
                                        <p class="mb-0 mt-2">@Localizer["Manage_2FA_OneCodeBeforeLink"] <a asp-page="./GenerateRecoveryCodes">@Localizer["Manage_2FA_GenerateLink"]</a>@Localizer["Manage_2FA_OneCodeAfterLink"]</p>
                                    </div>
                                }
                                else if (Model.RecoveryCodesLeft <= 3)
                                {
                                    <div class="alert alert-warning" role="alert">
                                        <i class="fas fa-exclamation-triangle me-2"></i>
                                        <strong>@string.Format(Localizer["Manage_2FA_CodesLeft"], Model.RecoveryCodesLeft)</strong>
                                        <p class="mb-0 mt-2">@Localizer["Manage_2FA_CodesLeftBeforeLink"] <a asp-page="./GenerateRecoveryCodes">@Localizer["Manage_2FA_GenerateLink"]</a>@Localizer["Manage_2FA_CodesLeftAfterLink"]</p>
                                    </div>
                                }

                                <div class="mb-4">
                                    <h5 class="mb-3">@Localizer["Manage_2FA_Status"]</h5>
                                    <div class="alert alert-success" role="alert">
                                        <i class="fas fa-check-circle me-2"></i>
                                        <strong>@Localizer["Manage_2FA_Enabled"]</strong>
                                    </div>
                                </div>

                                <div class="d-grid gap-2 mb-4">
                                    <a asp-page="./GenerateRecoveryCodes" class="btn btn-warning btn-sm">
                                        <i class="fas fa-sync me-1"></i>@Localizer["Manage_2FA_ResetCodes"]
                                    </a>
                                    <a asp-page="./Disable2fa" class="btn btn-danger btn-sm">
                                        <i class="fas fa-times me-1"></i>@Localizer["Manage_2FA_Disable"]
                                    </a>

                                    @if (Model.IsMachineRemembered)
                                    {
                                        <form method="post" class="d-grid">
                                            <button type="submit" class="btn btn-outline-secondary btn-sm">
                                                <i class="fas fa-trash me-1"></i>@Localizer["Manage_2FA_ForgetBrowser"]
                                            </button>
                                        </form>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-warning" role="alert">
                                    <i class="fas fa-exclamation-triangle me-2"></i>
                                    <strong>@Localizer["Manage_2FA_NotEnabled"]</strong>
                                    <p class="mb-0 mt-2">@Localizer["Manage_2FA_EnableHint"]</p>
                                </div>
                            }

                            <hr class="my-4">

                            <h5 class="mb-3">
                                <i class="fas fa-key me-2 text-info"></i>@Localizer["Manage_2FA_AuthenticatorApp"]
                            </h5>

                            <div class="d-grid gap-2">
                                @if (!Model.HasAuthenticator)
                                {
                                    <a id="enable-authenticator" asp-page="./EnableAuthenticator" class="btn btn-primary">
                                        <i class="fas fa-plus me-1"></i>@Localizer["Manage_2FA_AddApp"]
                                    </a>
                                }
                                else
                                {
                                    <a id="enable-authenticator" asp-page="./EnableAuthenticator" class="btn btn-primary">
                                        <i class="fas fa-cog me-1"></i>@Localizer["Manage_2FA_ConfigureApp"]
                                    </a>
                                    <a id="reset-authenticator" asp-page="./ResetAuthenticator" class="btn btn-outline-warning">
                                        <i class="fas fa-sync me-1"></i>@Localizer["Manage_2FA_ResetAuthenticator"]
                                    </a>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-danger" role="alert">
                                <i class="fas fa-info-circle me-2"></i>
                                <strong>@Localizer["Manage_2FA_PrivacyRequired"]</strong>
                                <p class="mb-0 mt-2">@Localizer["Manage_2FA_PrivacyHint"]</p>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
