@page
@model SetPasswordModel
@{
    ViewData["Title"] = Localizer["Manage_SetPassword_Title"];
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-3 col-md-4 mb-4 mb-md-0">
            <partial name="_ManageNav" />
        </div>
        <div class="col-lg-9 col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-5">
                    <h3>@Localizer["Manage_SetPassword_Heading"]</h3>
                    <partial name="_StatusMessage" for="StatusMessage" />
                    <p class="text-info">
                        @Localizer["Manage_SetPassword_Info"]
                    </p>
                    <form id="set-password-form" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                        <div class="form-floating mb-3">
                            <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" placeholder="@Localizer["Account_PlaceholderNewPassword"]"/>
                            <label asp-for="Input.NewPassword" class="form-label">@Localizer["Account_NewPassword"]</label>
                            <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                        </div>
                        <div class="form-floating mb-3">
                            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="@Localizer["Account_PlaceholderConfirmPassword"]"/>
                            <label asp-for="Input.ConfirmPassword" class="form-label">@Localizer["Account_ConfirmPassword"]</label>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>
                        <button type="submit" class="w-100 btn btn-lg btn-primary">@Localizer["Manage_SetPassword_Submit"]</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
