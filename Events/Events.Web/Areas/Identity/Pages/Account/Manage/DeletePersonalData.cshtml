@page
@model DeletePersonalDataModel
@{
    ViewData["Title"] = Localizer["Manage_Delete_Title"];
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card shadow-sm border-0">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <i class="fas fa-trash-alt fa-3x text-danger mb-3"></i>
                        <h2 class="fw-bold">@ViewData["Title"]</h2>
                        <p class="text-muted">@Localizer["Manage_Delete_Subtitle"]</p>
                    </div>

                    <div class="alert alert-danger" role="alert">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        @Localizer["Manage_Delete_Warning"]
                    </div>

                    <form id="delete-user" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        
                        @if (Model.RequirePassword)
                        {
                            <div class="mb-4">
                                <label asp-for="Input.Password" class="form-label">
                                    <i class="fas fa-lock me-2"></i>@Localizer["Manage_Delete_ConfirmPassword"]
                                </label>
                                <input asp-for="Input.Password" class="form-control form-control-lg" type="password" autocomplete="current-password" aria-required="true" placeholder="@Localizer["Manage_Delete_PasswordPlaceholder"]" />
                                <span asp-validation-for="Input.Password" class="text-danger"></span>
                                <small class="text-muted d-block mt-2">
                                    @Localizer["Manage_Delete_PasswordHint"]
                                </small>
                            </div>
                        }
                        
                        <div class="d-grid gap-2">
                            <button class="btn btn-danger btn-lg" type="submit">
                                <i class="fas fa-trash-alt me-2"></i>@Localizer["Manage_Delete_Submit"]
                            </button>
                            <a asp-page="./PersonalData" class="btn btn-outline-secondary btn-lg text-decoration-none">
                                <i class="fas fa-times me-2"></i>@Localizer["Account_Cancel"]
                            </a>
                        </div>

                        <hr class="my-4">

                        <div class="text-center">
                            <small class="text-muted">
                                <i class="fas fa-info-circle me-1"></i>
                                @Localizer["Manage_Delete_Permanent"]
                            </small>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
