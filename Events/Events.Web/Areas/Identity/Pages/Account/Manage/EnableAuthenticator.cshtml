@page
@model EnableAuthenticatorModel
@{
    ViewData["Title"] = Localizer["Manage_EnableAuth_Title"];
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-5">
                    <partial name="_StatusMessage" for="StatusMessage" />

                    <div class="text-center mb-4">
                        <i class="fas fa-shield-alt fa-3x text-primary mb-3"></i>
                        <h2 class="fw-bold">@ViewData["Title"]</h2>
                        <p class="text-muted">@Localizer["Manage_EnableAuth_Subtitle"]</p>
                    </div>

                    <div class="alert alert-info" role="alert">
                        <i class="fas fa-info-circle me-2"></i>
                        @Localizer["Manage_EnableAuth_Info"]
                    </div>

                    <div class="mb-4">
                        <h5 class="mb-3">@Localizer["Manage_EnableAuth_Step1"]</h5>
                        <p class="text-muted small mb-2">@Localizer["Manage_EnableAuth_Step1Hint"]</p>
                        <ul class="small text-muted">
                            <li>
                                Microsoft Authenticator for
                                <a href="https://go.microsoft.com/fwlink/?Linkid=825072" target="_blank">Android</a> or
                                <a href="https://go.microsoft.com/fwlink/?Linkid=825073" target="_blank">iOS</a>
                            </li>
                            <li>
                                Google Authenticator for
                                <a href="https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2&hl=en" target="_blank">Android</a> or
                                <a href="https://itunes.apple.com/us/app/google-authenticator/id388497605?mt=8" target="_blank">iOS</a>
                            </li>
                        </ul>
                    </div>

                    <div class="mb-4">
                        <h5 class="mb-3">@Localizer["Manage_EnableAuth_Step2"]</h5>
                        <p class="text-muted small mb-3">@Localizer["Manage_EnableAuth_Step2Hint"]</p>
                        
                        <div class="text-center mb-3">
                            <div id="qrCode" class="mb-3"></div>
                            <div id="qrCodeData" data-url="@Model.AuthenticatorUri" style="display:none;"></div>
                        </div>

                        <div class="alert alert-secondary" role="alert">
                            <strong>@Localizer["Manage_EnableAuth_ManualKey"]</strong><br>
                            <code style="word-break: break-all;">@Model.SharedKey</code>
                            <small class="d-block mt-2">@Localizer["Manage_EnableAuth_ManualKeyHint"]</small>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h5 class="mb-3">@Localizer["Manage_EnableAuth_Step3"]</h5>
                        <p class="text-muted small mb-3">@Localizer["Manage_EnableAuth_Step3Hint"]</p>
                        
                        <form id="send-code" method="post">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                            
                            <div class="mb-3">
                                <label asp-for="Input.Code" class="form-label">
                                    <i class="fas fa-lock me-2"></i>@Localizer["Manage_EnableAuth_VerificationCode"]
                                </label>
                                <input asp-for="Input.Code" class="form-control form-control-lg text-center" autocomplete="off" placeholder="000000" />
                                <span asp-validation-for="Input.Code" class="text-danger"></span>
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fas fa-check me-2"></i>@Localizer["Manage_EnableAuth_Verify"]
                                </button>
                            </div>
                        </form>
                    </div>

                    <hr class="my-4">

                    <div class="text-center">
                        <a asp-page="./TwoFactorAuthentication" class="text-decoration-none">
                            <i class="fas fa-arrow-left me-1"></i>@Localizer["Account_Back"]
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
