@model IEnumerable<Events.Web.Models.Admin.AdminVenueListItemViewModel>
@{
    ViewData["Title"] = "Venue Management";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="h3 mb-0">Venue management</h1>
        <p class="text-muted mb-0">Manage canonical venues and their location aliases.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Unmapped" class="btn btn-outline-warning">
            <i class="fas fa-map-marker-alt me-1"></i>Unmapped locations
        </a>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i>New venue
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card stat-card border-start border-4 border-primary">
            <div class="card-body">
                <small class="text-muted">Total venues</small>
                <h3 class="mb-0">@Model.Count()</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card border-start border-4 border-success">
            <div class="card-body">
                <small class="text-muted">Total aliases</small>
                <h3 class="mb-0">@Model.Sum(v => v.AliasCount)</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card border-start border-4 border-warning">
            <div class="card-body">
                <small class="text-muted">Upcoming events mapped</small>
                <h3 class="mb-0">@Model.Sum(v => v.UpcomingEventsCount)</h3>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-map-marker-alt fa-2x mb-3"></i>
                <p>No venues yet. <a asp-action="Create">Create the first one.</a></p>
            </div>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Slug</th>
                        <th>City</th>
                        <th class="text-center">Aliases</th>
                        <th class="text-center">Upcoming</th>
                        <th class="text-center">Total events</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var venue in Model)
                    {
                        <tr>
                            <td>
                                <strong>@venue.Name</strong>
                                @if (!string.IsNullOrEmpty(venue.ShortName))
                                {
                                    <span class="badge bg-secondary ms-1">@venue.ShortName</span>
                                }
                            </td>
                            <td><code>@venue.Slug</code></td>
                            <td>@venue.City</td>
                            <td class="text-center">
                                <span class="badge bg-primary">@venue.AliasCount</span>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-success">@venue.UpcomingEventsCount</span>
                            </td>
                            <td class="text-center">@venue.TotalEventsCount</td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@venue.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-edit me-1"></i>Edit
                                </a>
                                <form asp-action="Delete" asp-route-id="@venue.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Delete venue \'@venue.Name\'? This will not delete associated events.');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-trash me-1"></i>Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
